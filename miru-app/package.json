{
  "name": "miru-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,html}\" \"scripts/**/*.{js,mjs}\" \"tests/**/*.js\" \"*.{js,mjs,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,html}\" \"scripts/**/*.{js,mjs}\" \"tests/**/*.js\" \"*.{js,mjs,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit": "node scripts/audit-data.js",
    "audit:json": "node scripts/audit-data.js --json",
    "validate": "node scripts/validate-data.mjs"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
